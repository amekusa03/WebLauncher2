<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ★ファビコン取得に必須 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WebLauncher2">

        <!-- 管理画面（ドロアにはこれだけ表示） -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="あわ茶 設定">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ★singleInstance・taskAffinity削除済み -->
        <activity
            android:name=".SlotLauncherActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- ★intent-filter削除でドロアから非表示 -->
        <activity-alias
            android:name=".Slot1"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Slot 1"
            android:targetActivity=".SlotLauncherActivity" />

        <activity-alias
            android:name=".Slot2"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Slot 2"
            android:targetActivity=".SlotLauncherActivity" />

        <activity-alias
            android:name=".Slot3"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Slot 3"
            android:targetActivity=".SlotLauncherActivity" />

        <activity-alias
            android:name=".Slot4"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Slot 4"
            android:targetActivity=".SlotLauncherActivity" />

        <activity-alias
            android:name=".Slot5"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Slot 5"
            android:targetActivity=".SlotLauncherActivity" />

    </application>
</manifest>
